pipeline {
    agent any

    tools {
        maven 'maven-3.9.12'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/awslearning333/sysfoo.git'
            }
        }

        stage('Build') {
            steps {
                sh 'ls -l'
                sh 'mvn compile'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package'
            }
        }

        stage('Run Application') {
            steps {
                sh 'nohup java -jar target/*.jar --server.port=8081 > app.log 2>&1 &'
            }
        }

    }
}
